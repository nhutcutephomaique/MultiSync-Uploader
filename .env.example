# Vui lòng đổi tên file này thành .env.local và điền các giá trị thực tế

# Database URL (PostgreSQL từ Supabase, Neon hoặc Local)
DATABASE_URL="postgresql://user:password@localhost:5432/video_uploader?schema=public"

# NextAuth Secret: (Có thể tạo bằng lệnh `npx auth secret`)
AUTH_SECRET="your-secret-key-at-least-32-chars-long"
# Base URL (Chỉnh lại nếu deploy trên Vercel/VPS)
AUTH_URL="http://localhost:3000/api/auth"

# Facebook OAuth
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""

# Google (YouTube) OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# TikTok OAuth
AUTH_TIKTOK_ID=""
AUTH_TIKTOK_SECRET=""

# Mặc định Gemini API Key (Key của hệ thống - User có thể ghi đè trong Settings)
GEMINI_API_KEY=""
